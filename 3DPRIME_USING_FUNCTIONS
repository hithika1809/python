"""_________________________3D PRIME USING FUNCTIONS_____________________"""
def prime(n):
  if n<=1:
    return False
  else:
    for i in range(2,n):
      if n%i == 0:
        return False
    return True

def sod(n):
  d = [int(i) for i in str(n)]
  return sum(d)

def every(n):
  for i in range(3):
    d = n%10
    n = n//10
    if not prime(d):
      return False
  return True

for j in range(100,1000):
  if prime(j) and prime(sod(j)) and every(j):
